{
  "schemaVersion": 1,
  "id": "scavenger_extra_trials",
  "version": "${mod_version}",
  "name": "Scavenger Extra Trials",
  "description": "Unofficial Fabric add-on for Scavenger. Adds extra modifiers to the original Scavenger wheel.",
  "authors": [
    "joive"
  ],
  "license": "All Rights Reserved",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.joive.scavengerextratrials.ScavengerExtraTrials"
    ],
    "client": [
      "com.joive.scavengerextratrials.ScavengerExtraTrialsClient"
    ]
  },
  "mixins": [
    "scavenger_extra_trials.fabric.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${fabric_loader_version}",
    "minecraft": "${minecraft_version}",
    "fabric-api": "*",
    "architectury": ">=19.0.1",
    "scavenger": ">=1.0.2",
    "shatterlib": ">=0.6.0.8"
  }
}
